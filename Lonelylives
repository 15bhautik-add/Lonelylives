    <style>
        :root {
            --nature-green: #2d6a4f;
            --soft-cream: #f9f7f2;
            --accent-orange: #fb8500;
            --glass-bg: rgba(255, 255, 255, 0.75);
        }

        body {
            font-family: 'Hind Vadodara', 'Baloo Bhai 2', sans-serif;
            background: var(--soft-cream);
            color: #1b4332;
            overflow-x: hidden;
            scroll-behavior: smooth;
        }

        /* Lightened Leaf Animation */
        .leaf-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
        }

        .leaf {
            position: absolute;
            width: 25px;
            height: 25px;
            background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="%23d8f3dc"><path d="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 2,11.5 2,13.5C2,15.5 3.75,17.25 3.75,17.25C7,8 17,8 17,8Z"/></svg>') no-repeat;
            opacity: 0.2; 
            animation: fall linear infinite;
        }

        @keyframes fall {
            0% { transform: translateY(-10vh) rotate(0deg) translateX(0); }
            50% { transform: translateY(50vh) rotate(180deg) translateX(20px); }
            100% { transform: translateY(110vh) rotate(360deg) translateX(-20px); }
        }

        .glass {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.4);
            box-shadow: 0 8px 32px rgba(0,0,0,0.05);
        }

        .pop-effect {
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .pop-effect:hover {
            transform: scale(1.05) translateY(-5px);
            box-shadow: 0 15px 30px rgba(45, 106, 79, 0.15);
        }

        .nav-link:after {
            content: '';
            display: block;
            width: 0;
            height: 2px;
            background: var(--accent-orange);
            transition: width .3s;
        }
        .nav-link:hover:after { width: 100%; }

        .modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(8px);
            z-index: 100;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .modal.active { display: flex; animation: fadeIn 0.3s ease; }
        
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        .floating-donate {
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 40;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(251, 133, 0, 0.7); }
            70% { transform: scale(1.05); box-shadow: 0 0 0 15px rgba(251, 133, 0, 0); }
            100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(251, 133, 0, 0); }
        }
    </style>
</head>
