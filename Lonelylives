    <script>
        const leafContainer = document.getElementById('leafContainer');
        function createLeaf() {
            const leaf = document.createElement('div');
            leaf.classList.add('leaf');
            leaf.style.left = Math.random() * 100 + 'vw';
            leaf.style.animationDuration = Math.random() * 5 + 7 + 's';
            leafContainer.appendChild(leaf);
            setTimeout(() => leaf.remove(), 12000);
        }
        setInterval(createLeaf, 600);

        const pets = [
            { id: 1, name: "શેરુ", age: "૨ વર્ષ", location: "સંતરામ રોડ, નડિયાદ", img: "https://images.unsplash.com/photo-1583512603805-3cc6b41f3edb?auto=format&fit=crop&q=80&w=400", type: "કૂતરો" },
            { id: 2, name: "માનો", age: "૬ મહિના", location: "વી.વી. નગર, આણંદ", img: "https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba?auto=format&fit=crop&q=80&w=400", type: "બિલાડી" },
            { id: 3, name: "બ્રુનો", age: "૧ વર્ષ", location: "પીપલગ, નડિયાદ", img: "https://images.unsplash.com/photo-1552053831-71594a27632d?auto=format&fit=crop&q=80&w=400", type: "કૂતરો" },
            { id: 4, name: "મોતી", age: "૫ વર્ષ", location: "સ્ટેશન રોડ, નડિયાદ", img: "https://images.unsplash.com/photo-1543466835-00a7907e9de1?auto=format&fit=crop&q=80&w=400", type: "કૂતરો" }
        ];

        const foods = [
            { name: "પ્રીમિયમ ડોગ ફૂડ", price: "₹૮૫૦", img: "https://images.unsplash.com/photo-1568640347023-a616a30bc3bd?auto=format&fit=crop&q=80&w=400" },
            { name: "કેટ બિસ્કિટ", price: "₹૪૦૦", img: "https://images.unsplash.com/photo-1583337130417-3346a1be7dee?auto=format&fit=crop&q=80&w=400" }
        ];

        function renderUI() {
            document.getElementById('petGrid').innerHTML = pets.map(pet => `
                <div class="glass rounded-[40px] overflow-hidden pop-effect">
                    <img src="${pet.img}" class="w-full h-48 object-cover">
                    <div class="p-6">
                        <div class="flex justify-between mb-2"><span class="font-black text-xl text-green-900">${pet.name}</span><span class="text-orange-600 font-bold">${pet.age}</span></div>
                        <p class="text-sm text-green-700 mb-6"><i class="fas fa-map-marker-alt"></i> ${pet.location}</p>
                        <button onclick="showAdopt(${pet.id})" class="w-full bg-green-700 text-white py-3 rounded-2xl font-bold">દત્તક લો</button>
                    </div>
                </div>
            `).join('');

            document.getElementById('foodGrid').innerHTML = foods.map(food => `
                <div class="glass p-6 rounded-[40px] text-center pop-effect">
                    <img src="${food.img}" class="w-40 h-40 object-cover mx-auto rounded-3xl mb-4 shadow-lg">
                    <h4 class="text-lg font-bold">${food.name}</h4>
                    <p class="text-orange-600 font-black text-xl my-2">${food.price}</p>
                    <button onclick="window.location.href='https://wa.me/9313529202?text=I want to order ${food.name}'" class="text-green-700 font-bold border-2 border-green-700 px-6 py-2 rounded-xl">ઓર્ડર કરો</button>
                </div>
            `).join('');
        }

        function openModal(id) { document.getElementById(id).classList.add('active'); }
        function closeModal(id) { document.getElementById(id).classList.remove('active'); }
        function closeModalOnOuterClick(e, id) { if(e.target.id === id) closeModal(id); }

        function submitDonation() {
            const amount = document.getElementById('donateAmount').value;
            if (!amount || amount < 10) {
                const msg = document.createElement('div');
                msg.className = 'fixed top-10 left-1/2 -translate-x-1/2 bg-red-500 text-white px-6 py-3 rounded-xl z-[200] shadow-xl';
                msg.innerText = "કૃપા કરીને ઓછામાં ઓછી ₹૧૦ ની રકમ લખો.";
                document.body.appendChild(msg);
                setTimeout(() => msg.remove(), 3000);
                return;
            }
            window.open(`https://wa.me/9313529202?text=I want to donate ₹${amount} to Lonelylives.`, '_blank');
        }

        function showAdopt(id) {
            const pet = pets.find(p => p.id === id);
            document.getElementById('petInfo').innerHTML = `
                <img src="${pet.img}" class="w-32 h-32 rounded-full mx-auto object-cover border-4 border-orange-200 mb-4 shadow-xl">
                <h3 class="text-2xl font-black text-green-900">${pet.name} ને મળો</h3>
                <p class="text-green-700">${pet.age} • ${pet.location}</p>
            `;
            document.getElementById('wpAction').href = `https://wa.me/9313529202?text=I want to adopt ${pet.name}.`;
            openModal('adoptModal');
        }

        window.onload = renderUI;
    </script>
</body>
</html>
